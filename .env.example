# ─── Free5E Character Creator ────────────────────────────────
# All variables below are OPTIONAL for Docker deployments.
# Copy this file to .env and fill in what you need.

# ─── Core ────────────────────────────────────────────────────
# DATABASE_URL     — Path to SQLite file (default: local.db in dev, /data/free5e.db in Docker)
# DATABASE_URL=local.db

# AUTH_SECRET      — Signs session cookies. Auto-generated in Docker if not set.
#                    For local dev, any random string works.
# AUTH_SECRET=change-me

# AUTH_TRUST_HOST  — Set to true behind a reverse proxy. Baked into Docker image.
# AUTH_TRUST_HOST=true

# ─── Google OAuth (optional) ────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-domain.com/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ─── Discord OAuth (optional) ───────────────────────────────
# Create an app at: https://discord.com/developers/applications
# Redirects: https://your-domain.com/auth/callback/discord
# AUTH_DISCORD_ID=
# AUTH_DISCORD_SECRET=

# ─── Advanced ───────────────────────────────────────────────
# CONTENT_PACKS_DIR — Override default content-packs directory
# CONTENT_PACKS_DIR=/path/to/custom/content-packs

# PORT             — Server port (default: 3000)
# PORT=3000

# DEPLOY_TARGET    — Build target: "node" (default) or "cloudflare"
# DEPLOY_TARGET=node
